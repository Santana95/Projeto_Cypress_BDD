# ========================================================
# .env.example - Copie este arquivo para .env e configure
# ========================================================
# Não commitá este arquivo com dados reais de produção!
# Mantenha apenas em repositório o .env.example

# URL Base da Aplicação
BASE_URL=http://automationpratice.com.br

# Ambientes alternativos
# BASE_URL=http://staging.automationpratice.com.br
# BASE_URL=http://localhost:3000
# BASE_URL=https://automationpratice.com.br

# Credenciais de Teste (NUNCA commitar com dados reais!)
# Descomentar apenas para desenvolvimento local
# CYPRESS_USUARIO_TESTE=usuario@teste.com
# CYPRESS_SENHA_TESTE=senhaSegura123!

# Timeout padrão (em ms)
CYPRESS_DEFAULT_COMMAND_TIMEOUT=10000

# Configurações de Browser
# CYPRESS_BROWSER=chrome
# CYPRESS_BROWSER=firefox

# Configurações de Relatório
CYPRESS_REPORT_DIR=cypress/reports
CYPRESS_REPORT_TITLE=Projeto_Cypress_BDD
